{
  "name": "sp-search-engine",
  "version": "1.0.0",
  "description": "Search API with SQS/RabbitMQ-backed OpenSearch synchronization.",
  "main": "handler.js",
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "node --test test/queue-client.test.js test/queue-item-schema.test.js test/queue-processor.test.js test/queue-worker-handler.test.js",
    "test:integration:es:ingest": "node test/es-ingestion-api.test.js",
    "test:integration:es:search": "node test/es-search-api.test.js",
    "test:integration:os:ingest": "node test/os-ingestion-api.test.js",
    "test:integration:os:search": "node test/os-search-api.test.js",
    "start": "sls offline start",
    "start:offline": "sls offline start --host 0.0.0.0",
    "queue:worker": "node src/workers/queueWorker.js",
    "deploy:staging": "sls deploy --stage staging",
    "deploy:production": "sls deploy --stage production"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/credential-provider-node": "^3.848.0",
    "@elastic/elasticsearch": "^8.17.1",
    "@opensearch-project/opensearch": "^3.5.1",
    "amqplib": "^0.10.4",
    "aws-sdk": "^2.1692.0",
    "dotenv": "^16.5.0",
    "mysql2": "^3.14.1",
    "serverless": "^3.30.1"
  },
  "devDependencies": {
    "serverless-domain-manager": "^8.0.0",
    "serverless-offline": "^12.0.4"
  }
}
